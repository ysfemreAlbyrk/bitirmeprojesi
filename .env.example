# Database Configuration
SUPABASE_URL=http://localhost:8000
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# AI Configuration
LLM_PROVIDER=gemini  # Options: gemini, ollama
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# MMAudio Configuration
MMAUDIO_PATH=~/mm/MMAudio

# Image Generation Configuration
IMAGE_GENERATION_MODEL=clipdrop  # Options: clipdrop, local
IMAGE_GENERATION_PATH=~/models/sdxl-turbo
CLIPDROP_API_KEY=your_clipdrop_api_key

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
MAX_FILE_SIZE=50000000  # 50MB

# Storage Configuration
STORAGE_BUCKET_NAME=media-assets
