# Database Configuration
SUPABASE_URL=http://localhost:8000
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# AI Configuration
LLM_PROVIDER=gemini  # Options: gemini, ollama
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# MMAudio Configuration
MMAUDIO_PATH=~/mm/MMAudio

# Image Generation Configuration
IMAGE_GENERATION_MODEL=clipdrop  # Options: clipdrop, local
IMAGE_GENERATION_PATH=~/models/sdxl-turbo
CLIPDROP_API_KEY=your_clipdrop_api_key

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
MAX_FILE_SIZE=50000000  # 50MB

# Storage Configuration
STORAGE_BUCKET_NAME=media-assets

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# Database Connection Pool Configuration
DB_POOL_CONNECTIONS=10
DB_POOL_MAXSIZE=100
DB_CONNECTION_TIMEOUT=30
DB_READ_TIMEOUT=30
DB_WRITE_TIMEOUT=30

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=memory  # Options: memory, redis

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=1800  # 30 minutes in seconds
